{% block headStyles %}
<style>
.upload-zone {
    border: 1.5px dashed var(--border-strong);
    border-radius: var(--radius-lg);
    padding: var(--sp-8);
    text-align: center;
    margin-bottom: var(--sp-5);
    background: var(--surface);
    cursor: pointer;
    transition: all 0.15s ease;
}
.upload-zone:hover { border-color: var(--accent); background: var(--accent-light); }
.upload-zone .material-icons-outlined { font-size: 32px; color: var(--accent); margin-bottom: var(--sp-2); }
.upload-zone h4 { margin-bottom: var(--sp-1); }
.upload-zone p { font-size: 0.78rem; color: var(--faded); }
</style>
{% endblock %}

{% block content %}
<div class="content">
    <div class="page-header">
        <h1>Payout Batches</h1>
        <button class="btn btn-primary" onclick="document.getElementById('uploadZone').style.display=document.getElementById('uploadZone').style.display==='none'?'block':'none'">
            <span class="material-icons-outlined">upload_file</span> Upload CSV
        </button>
    </div>

    <!-- Upload Zone (toggled) -->
    <div id="uploadZone" class="upload-zone" style="display:none">
        <span class="material-icons-outlined">cloud_upload</span>
        <h4>Drop your payout CSV here</h4>
        <p>Supported format: CSV with columns Retailer ID, Amount, Reward Type. Max 10,000 rows per batch.</p>
    </div>

    <!-- Filter Pills -->
    <div class="filter-pills">
        <span class="filter-pill active">All Batches</span>
        <span class="filter-pill">Uploaded</span>
        <span class="filter-pill">Validating</span>
        <span class="filter-pill">Processing</span>
        <span class="filter-pill">Completed</span>
        <span class="filter-pill">Failed</span>
