---
layout: base.njk
title: Wallet
navActive: /05-wallet.html
permalink: /05-wallet.html
---
{% block headStyles %}
<style>
.balance-card {
    background: linear-gradient(135deg, var(--dark-blue) 0%, #1a3a6b 100%);
    border-radius: 16px;
    padding: 32px 36px;
    color: var(--white);
    margin-bottom: 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 20px;
}
.balance-card .balance-label { font-size: 0.9rem; opacity: 0.7; margin-bottom: 4px; }
.balance-card .balance-amount { font-family: 'Kanit', sans-serif; font-weight: 800; font-size: 2.5rem; }
.balance-card .balance-sub { font-size: 0.82rem; opacity: 0.6; margin-top: 4px; }
.balance-actions { display: flex; gap: 12px; }
.balance-actions .btn { background: rgba(255,255,255,0.15); color: var(--white); border: 1px solid rgba(255,255,255,0.2); }
.balance-actions .btn:hover { background: rgba(255,255,255,0.25); }
</style>
{% endblock %}

{% block content %}
<div class="content">
    <div class="page-header">
        <h1>Wallet</h1>
    </div>

    <!-- Balance Card -->
    <div class="balance-card">
        <div>
            <div class="balance-label">Current Balance</div>
            <div class="balance-amount">&#8377;24,50,000</div>
            <div class="balance-sub">Last funded: 26 Mar 2026 via NEFT &middot; UTR: HDFC0026032612345</div>
        </div>
        <div class="balance-actions">
            <button class="btn"><span class="material-icons-outlined">add</span> Fund Wallet</button>
            <button class="btn"><span class="material-icons-outlined">download</span> Statement</button>
        </div>
    </div>

    <!-- Filter Pills -->
    <div class="filter-pills">
        <span class="filter-pill active">All Transactions</span>
        <span class="filter-pill">Credit</span>
        <span class="filter-pill">Debit</span>
    </div>

    <div class="filter-pills" style="margin-top:-12px">
        <span style="font-size:0.82rem;color:var(--text-secondary);margin-right:8px">Category:</span>
        <span class="filter-pill active">All</span>
        <span class="filter-pill">Funding</span>
        <span class="filter-pill">Payout</span>
        <span class="filter-pill">KYC Fee</span>
        <span class="filter-pill">Platform Fee</span>
    </div>

    <!-- Transaction Ledger -->
    <div class="section-card">
        <div class="section-header">
            <div class="section-title">
                <span class="material-icons-outlined">receipt</span>
                <h3>Transaction Ledger</h3>
            </div>
            <button class="btn btn-sm btn-outline">
                <span class="material-icons-outlined">download</span> Export
            </button>
        </div>
        <div class="table-scroll-wrapper">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Type</th>
                    <th>Category</th>
                    <th>Description</th>
                    <th>Amount</th>
                    <th>Balance After</th>
                    <th>UTR / Ref</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>28 Mar 2026</td>
                    <td><span class="badge red">Debit</span></td>
                    <td><span class="badge blue">Payout</span></td>
                    <td>BTH-2026-0387 (1,218 payouts)</td>
                    <td style="color:var(--error);font-weight:600">- &#8377;8,42,400</td>
                    <td>&#8377;24,50,000</td>
                    <td style="font-family:monospace;font-size:0.82rem">INT-0387-NET</td>
                </tr>
                <tr>
                    <td>28 Mar 2026</td>
                    <td><span class="badge red">Debit</span></td>
                    <td><span class="badge purple">Platform Fee</span></td>
                    <td>Processing fee - BTH-2026-0387</td>
                    <td style="color:var(--error);font-weight:600">- &#8377;12,180</td>
                    <td>&#8377;32,92,400</td>
                    <td style="font-family:monospace;font-size:0.82rem">FEE-0387</td>
                </tr>
                <tr>
                    <td>26 Mar 2026</td>
                    <td><span class="badge green">Credit</span></td>
                    <td><span class="badge green">Funding</span></td>
                    <td>NEFT deposit - Abbott India Ltd</td>
                    <td style="color:var(--success);font-weight:600">+ &#8377;50,00,000</td>
                    <td>&#8377;33,04,580</td>
                    <td style="font-family:monospace;font-size:0.82rem">HDFC0026032612345</td>
                </tr>
                <tr>
                    <td>25 Mar 2026</td>
                    <td><span class="badge red">Debit</span></td>
                    <td><span class="badge blue">Payout</span></td>
                    <td>BTH-2026-0386 (975 payouts)</td>
                    <td style="color:var(--error);font-weight:600">- &#8377;5,61,600</td>
                    <td>&#8377;-16,95,420</td>
                    <td style="font-family:monospace;font-size:0.82rem">INT-0386-NET</td>
                </tr>
                <tr>
                    <td>25 Mar 2026</td>
                    <td><span class="badge red">Debit</span></td>
                    <td><span class="badge purple">Platform Fee</span></td>
                    <td>Processing fee - BTH-2026-0386</td>
                    <td style="color:var(--error);font-weight:600">- &#8377;9,750</td>
                    <td>&#8377;-11,33,820</td>
                    <td style="font-family:monospace;font-size:0.82rem">FEE-0386</td>
                </tr>
                <tr>
                    <td>22 Mar 2026</td>
                    <td><span class="badge red">Debit</span></td>
                    <td><span class="badge yellow">KYC Fee</span></td>
