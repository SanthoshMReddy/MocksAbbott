                    <td style="color:var(--error);font-weight:600">- &#8377;7,100</td>
                    <td>&#8377;-11,24,070</td>
                    <td style="font-family:monospace;font-size:0.82rem">KYC-BATCH-0322</td>
                </tr>
                <tr>
                    <td>20 Mar 2026</td>
                    <td><span class="badge green">Credit</span></td>
                    <td><span class="badge green">Funding</span></td>
                    <td>RTGS deposit - Abbott India Ltd</td>
