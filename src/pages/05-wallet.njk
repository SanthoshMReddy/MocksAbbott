                    <td>&#8377;-11,16,970</td>
                    <td style="font-family:monospace;font-size:0.82rem">ICIC0020032056789</td>
                </tr>
                <tr>
                    <td>18 Mar 2026</td>
                    <td><span class="badge red">Debit</span></td>
                    <td><span class="badge blue">Payout</span></td>
                    <td>BTH-2026-0382 (2,089 payouts)</td>
                    <td style="color:var(--error);font-weight:600">- &#8377;13,23,000</td>
                    <td>&#8377;-36,16,970</td>
                    <td style="font-family:monospace;font-size:0.82rem">INT-0382-NET</td>
                </tr>
            </tbody>
        </table>
        </div>

        <div class="pagination">
            <div class="pagination-info">Showing 1-8 of 246 transactions</div>
            <div class="pagination-buttons">
                <button class="page-btn nav-btn"><span class="material-icons-outlined">chevron_left</span> Prev</button>
                <button class="page-btn active">1</button>
