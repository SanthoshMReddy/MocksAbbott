---
layout: base.njk
title: Wallet
navActive: /05-wallet.html
permalink: /05-wallet.html
---
{% block headStyles %}
<style>
.balance-card {
    background: var(--navy);
    border-radius: var(--radius-lg);
    padding: var(--sp-8) var(--sp-8);
    color: #fff;
    margin-bottom: var(--sp-6);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--sp-5);
}
.balance-card .balance-label { font-size: 0.78rem; opacity: 0.55; margin-bottom: var(--sp-1); text-transform: uppercase; letter-spacing: 0.04em; font-weight: 600; }
.balance-card .balance-amount { font-family: 'Kanit', sans-serif; font-weight: 800; font-size: 2.25rem; letter-spacing: -0.02em; }
.balance-card .balance-sub { font-size: 0.75rem; opacity: 0.45; margin-top: var(--sp-1); }
.balance-actions { display: flex; gap: var(--sp-3); }
.balance-actions .btn {
    background: rgba(255,255,255,0.1);
    color: #fff;
    border: 1px solid rgba(255,255,255,0.15);
    font-size: 0.78rem;
}
.balance-actions .btn:hover { background: rgba(255,255,255,0.18); }
</style>
{% endblock %}

{% block content %}
<div class="content">
    <div class="page-header">
        <h1>Wallet</h1>
    </div>

    <!-- Balance Card -->
    <div class="balance-card">
        <div>
            <div class="balance-label">Current Balance</div>
            <div class="balance-amount">&#8377;24,50,000</div>
            <div class="balance-sub">Last funded: 26 Mar 2026 via NEFT &middot; UTR: HDFC0026032612345</div>
        </div>
        <div class="balance-actions">
            <button class="btn"><span class="material-icons-outlined">add</span> Fund Wallet</button>
            <button class="btn"><span class="material-icons-outlined">download</span> Statement</button>
        </div>
    </div>

    <!-- Filter Pills -->
    <div class="filter-pills">
        <span class="filter-pill active">All Transactions</span>
        <span class="filter-pill">Credit</span>
        <span class="filter-pill">Debit</span>
    </div>

    <div class="filter-pills" style="margin-top:calc(-1 * var(--sp-2))">
        <span style="font-size:0.78rem;color:var(--faded);margin-right:var(--sp-2)">Category:</span>
        <span class="filter-pill active">All</span>
        <span class="filter-pill">Funding</span>
        <span class="filter-pill">Payout</span>
        <span class="filter-pill">KYC Fee</span>
        <span class="filter-pill">Platform Fee</span>
    </div>

    <!-- Transaction Ledger -->
    <div class="section-card">
        <div class="section-header">
            <div class="section-title">
                <span class="material-icons-outlined">receipt</span>
                <h3>Transaction Ledger</h3>
            </div>
            <button class="btn btn-sm btn-outline">
                <span class="material-icons-outlined">download</span> Export
            </button>
        </div>
        <div class="table-scroll-wrapper">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Type</th>
                    <th>Category</th>
                    <th>Description</th>
                    <th>Amount</th>
                    <th>Balance After</th>
                    <th>UTR / Ref</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>28 Mar 2026</td>
                    <td><span class="badge red">Debit</span></td>
                    <td><span class="badge blue">Payout</span></td>
