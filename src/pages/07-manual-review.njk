---
layout: base.njk
title: Manual Review
navActive: /07-manual-review.html
permalink: /07-manual-review.html
---
{% block headStyles %}
<style>
.review-layout { display: grid; grid-template-columns: 320px 1fr; gap: var(--sp-5); min-height: calc(100vh - 160px); }

/* Left Panel - Case List */
.case-list { background: var(--surface); border-radius: var(--radius-lg); border: 1px solid var(--border); overflow: hidden; display: flex; flex-direction: column; }
.case-list-header { padding: var(--sp-4) var(--sp-5); border-bottom: 1px solid var(--border); }
.case-list-header h3 { font-size: 0.9rem; margin-bottom: var(--sp-2); }
.case-list-body { flex: 1; overflow-y: auto; }
.case-item {
    padding: var(--sp-3) var(--sp-5); border-bottom: 1px solid var(--border);
    cursor: pointer; transition: background 0.08s ease;
}
.case-item:hover { background: var(--canvas); }
.case-item.active { background: var(--accent-light); border-left: 2px solid var(--accent); }
.case-item .case-name { font-weight: 600; font-size: 0.85rem; margin-bottom: 1px; }
.case-item .case-meta { font-size: 0.72rem; color: var(--muted); }
.case-item .case-reason { font-size: 0.72rem; color: var(--error); margin-top: var(--sp-1); }

/* Right Panel - Detail View */
.case-detail { background: var(--surface); border-radius: var(--radius-lg); border: 1px solid var(--border); padding: var(--sp-6); }
.detail-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--sp-6); flex-wrap: wrap; gap: var(--sp-3); }
.detail-actions { display: flex; gap: var(--sp-2); }
.btn-reject { background: var(--error); color: #fff; }
.btn-reject:hover { background: #DC2626; }

.doc-compare { display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-5); margin-bottom: var(--sp-6); }
.doc-panel { border: 1px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; }
.doc-panel-header {
    background: var(--canvas); padding: var(--sp-2) var(--sp-4);
    font-weight: 600; font-size: 0.72rem; color: var(--faded);
    text-transform: uppercase; letter-spacing: 0.04em;
    display: flex; align-items: center; gap: var(--sp-2);
}
.doc-panel-body {
    padding: var(--sp-5); min-height: 180px;
    display: flex; align-items: center; justify-content: center;
    background: var(--canvas);
}
.doc-placeholder { text-align: center; color: var(--muted); }
.doc-placeholder .material-icons-outlined { font-size: 40px; margin-bottom: var(--sp-2); opacity: 0.3; }
.doc-placeholder p { font-size: 0.78rem; }

.entity-compare { margin-bottom: var(--sp-6); }
.entity-row {
    display: grid; grid-template-columns: 140px 1fr 1fr 64px;
    gap: var(--sp-3); padding: var(--sp-2) 0; border-bottom: 1px solid var(--border);
    align-items: center; font-size: 0.82rem;
}
.entity-row.header { font-weight: 600; font-size: 0.72rem; color: var(--faded); text-transform: uppercase; letter-spacing: 0.03em; }
.match-icon { display: flex; align-items: center; justify-content: center; }
.match-icon .material-icons-outlined { font-size: 18px; }
.match-icon.pass .material-icons-outlined { color: var(--success); }
.match-icon.fail .material-icons-outlined { color: var(--error); }
.match-icon.warn .material-icons-outlined { color: var(--warning); }

@media (max-width: 900px) {
    .review-layout { grid-template-columns: 1fr; }
    .doc-compare { grid-template-columns: 1fr; }
    .entity-row { grid-template-columns: 1fr 1fr; gap: var(--sp-2); }
}
</style>
{% endblock %}

{% block content %}
<div class="content">
    <div class="page-header">
        <h1>Manual Review Queue</h1>
        <span class="badge yellow" style="font-size:0.82rem;padding:var(--sp-1) var(--sp-3)">12 cases pending</span>
    </div>

    <div class="review-layout">
        <!-- Left: Case List -->
        <div class="case-list">
            <div class="case-list-header">
                <h3>Pending Cases</h3>
                <div class="content-search" style="margin-bottom:0">
                    <span class="material-icons-outlined">search</span>
                    <input type="text" placeholder="Search cases..." style="font-size:0.78rem">
                </div>
            </div>
            <div class="case-list-body">
                <div class="case-item active" onclick="selectCase(1)">
                    <div class="case-name">Jain Medical Agencies</div>
                    <div class="case-meta">GSTIN: 23AABCJ5432K1ZT &middot; Bhopal</div>
                    <div class="case-reason">Entity name mismatch (72% match)</div>
                </div>
                <div class="case-item" onclick="selectCase(2)">
                    <div class="case-name">Krishna Pharma Distributors</div>
                    <div class="case-meta">GSTIN: 29AABCK6789P1ZR &middot; Bangalore</div>
                    <div class="case-reason">Cancelled cheque name differs</div>
                </div>
                <div class="case-item" onclick="selectCase(3)">
                    <div class="case-name">Mehta Drug Agency</div>
                    <div class="case-meta">GSTIN: 24AABCM4321R1ZQ &middot; Surat</div>
                    <div class="case-reason">GSTIN certificate blurry</div>
                </div>
                <div class="case-item" onclick="selectCase(4)">
                    <div class="case-name">Saxena Medical House</div>
                    <div class="case-meta">GSTIN: 09AABCS1234T1ZN &middot; Agra</div>
                    <div class="case-reason">Bank account IFSC invalid</div>
                </div>
                <div class="case-item" onclick="selectCase(5)">
                    <div class="case-name">Roy Chemists Pvt Ltd</div>
                    <div class="case-meta">GSTIN: 19AABCR5678U1ZM &middot; Kolkata</div>
                    <div class="case-reason">Entity name mismatch (65% match)</div>
                </div>
                <div class="case-item" onclick="selectCase(6)">
                    <div class="case-name">Pillai Health Store</div>
                    <div class="case-meta">GSTIN: 32AABCP8901V1ZL &middot; Trivandrum</div>
                    <div class="case-reason">PAN not linked to GSTIN</div>
                </div>
                <div class="case-item" onclick="selectCase(7)">
                    <div class="case-name">Choudhary Pharma</div>
                    <div class="case-meta">GSTIN: 08AABCC2345W1ZK &middot; Jaipur</div>
                    <div class="case-reason">Cancelled cheque name differs</div>
                </div>
                <div class="case-item" onclick="selectCase(8)">
                    <div class="case-name">Das Medical Suppliers</div>
                    <div class="case-meta">GSTIN: 18AABCD6789X1ZJ &middot; Guwahati</div>
                    <div class="case-reason">Document expired</div>
                </div>
            </div>
        </div>

        <!-- Right: Detail View -->
        <div class="case-detail">
            <div class="detail-header">
                <div>
                    <h2>Jain Medical Agencies</h2>
                    <p style="color:var(--faded);font-size:0.78rem;margin-top:var(--sp-1)">
                        GSTIN: 23AABCJ5432K1ZT &middot; Bhopal, Madhya Pradesh &middot; Submitted 25 Mar 2026
                    </p>
                </div>
                <div class="detail-actions">
                    <button class="btn btn-reject"><span class="material-icons-outlined">close</span> Reject</button>
                    <button class="btn btn-success"><span class="material-icons-outlined">check</span> Approve</button>
                </div>
            </div>

            <!-- Document Comparison -->
            <h3 style="margin-bottom:var(--sp-3)">Document Comparison</h3>
            <div class="doc-compare">
                <div class="doc-panel">
                    <div class="doc-panel-header">
                        <span class="material-icons-outlined" style="font-size:14px">description</span>
                        GSTIN Certificate
                    </div>
                    <div class="doc-panel-body">
                        <div class="doc-placeholder">
                            <span class="material-icons-outlined">article</span>
                            <p>GSTIN Certificate Image</p>
                            <p style="font-size:0.68rem;margin-top:var(--sp-1)">Entity: "Jain Medical Agencies Pvt Ltd"</p>
                        </div>
                    </div>
                </div>
                <div class="doc-panel">
                    <div class="doc-panel-header">
                        <span class="material-icons-outlined" style="font-size:14px">account_balance</span>
                        Cancelled Cheque
                    </div>
                    <div class="doc-panel-body">
                        <div class="doc-placeholder">
                            <span class="material-icons-outlined">account_balance</span>
                            <p>Cancelled Cheque Image</p>
                            <p style="font-size:0.68rem;margin-top:var(--sp-1)">Account: "Jain Medicals"</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Entity Name Comparison -->
            <h3 style="margin-bottom:var(--sp-3)">Entity Name Verification</h3>
            <div class="entity-compare">
                <div class="entity-row header">
                    <div>Field</div>
                    <div>GSTIN Certificate</div>
                    <div>Bank Records</div>
                    <div>Match</div>
                </div>
                <div class="entity-row">
                    <div style="font-weight:500;color:var(--faded)">Legal Name</div>
                    <div>Jain Medical Agencies Pvt Ltd</div>
                    <div>Jain Medicals</div>
                    <div class="match-icon warn"><span class="material-icons-outlined">warning</span></div>
                </div>
                <div class="entity-row">
                    <div style="font-weight:500;color:var(--faded)">PAN</div>
                    <div>AABCJ5432K</div>
                    <div>AABCJ5432K</div>
                    <div class="match-icon pass"><span class="material-icons-outlined">check_circle</span></div>
                </div>
                <div class="entity-row">
                    <div style="font-weight:500;color:var(--faded)">Address</div>
                    <div>14, MG Road, Bhopal</div>
                    <div>14, M.G. Road, Bhopal</div>
                    <div class="match-icon pass"><span class="material-icons-outlined">check_circle</span></div>
                </div>
                <div class="entity-row">
                    <div style="font-weight:500;color:var(--faded)">Match Score</div>
                    <div style="color:var(--warning);font-weight:600">72% -- Below 85% auto-approve threshold</div>
                    <div></div>
                    <div class="match-icon warn"><span class="material-icons-outlined">warning</span></div>
                </div>
            </div>

            <!-- Notes -->
            <div>
                <h4 style="margin-bottom:var(--sp-2)">Review Notes</h4>
                <textarea style="width:100%;padding:var(--sp-3);border:1px solid var(--border);border-radius:var(--radius-md);font-family:'Inter',sans-serif;font-size:0.82rem;resize:vertical;min-height:72px;color:var(--ink);background:var(--canvas)" placeholder="Add notes for this review decision..."></textarea>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
function selectCase(n) {
    document.querySelectorAll('.case-item').forEach(function(el, i) {
        el.classList.toggle('active', i === n - 1);
    });
}
</script>
{% endblock %}
