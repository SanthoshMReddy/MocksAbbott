---
layout: base.njk
title: Manual Review
navActive: /07-manual-review.html
permalink: /07-manual-review.html
---
{% block headStyles %}
<style>
.review-layout { display: grid; grid-template-columns: 340px 1fr; gap: 24px; min-height: calc(100vh - 180px); }

/* Left Panel - Case List */
.case-list { background: var(--white); border-radius: 12px; border: 1px solid #E5E7EB; overflow: hidden; display: flex; flex-direction: column; }
.case-list-header { padding: 16px 20px; border-bottom: 1px solid #E5E7EB; }
.case-list-header h3 { font-size: 1rem; margin-bottom: 8px; }
.case-list-body { flex: 1; overflow-y: auto; }
.case-item {
    padding: 14px 20px; border-bottom: 1px solid #F3F4F6;
    cursor: pointer; transition: background 0.1s;
}
.case-item:hover { background: #F9FAFB; }
.case-item.active { background: var(--blue-light); border-left: 3px solid var(--blue); }
.case-item .case-name { font-weight: 600; font-size: 0.9rem; margin-bottom: 2px; }
.case-item .case-meta { font-size: 0.78rem; color: var(--text-secondary); }
.case-item .case-reason { font-size: 0.78rem; color: var(--error); margin-top: 4px; }

/* Right Panel - Detail View */
.case-detail { background: var(--white); border-radius: 12px; border: 1px solid #E5E7EB; padding: 28px; }
.detail-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; flex-wrap: wrap; gap: 12px; }
.detail-actions { display: flex; gap: 10px; }
.btn-reject { background: var(--error); color: var(--white); }
.btn-reject:hover { background: #DC2626; }

.doc-compare { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px; }
.doc-panel {
    border: 1px solid #E5E7EB; border-radius: 10px; overflow: hidden;
}
.doc-panel-header {
    background: #F9FAFB; padding: 10px 16px;
    font-weight: 600; font-size: 0.82rem; color: var(--text-secondary);
    text-transform: uppercase; letter-spacing: 0.03em;
    display: flex; align-items: center; gap: 8px;
}
.doc-panel-body {
    padding: 20px; min-height: 200px;
    display: flex; align-items: center; justify-content: center;
    background: var(--pale-blue);
}
.doc-placeholder {
    text-align: center; color: var(--text-secondary);
}
.doc-placeholder .material-icons-outlined { font-size: 48px; margin-bottom: 8px; opacity: 0.4; }
.doc-placeholder p { font-size: 0.82rem; }

.entity-compare { margin-bottom: 24px; }
.entity-row {
    display: grid; grid-template-columns: 160px 1fr 1fr 80px;
    gap: 12px; padding: 10px 0; border-bottom: 1px solid #F3F4F6;
    align-items: center; font-size: 0.88rem;
}
.entity-row.header { font-weight: 600; font-size: 0.8rem; color: var(--text-secondary); text-transform: uppercase; }
.match-icon { display: flex; align-items: center; justify-content: center; }
.match-icon .material-icons-outlined { font-size: 20px; }
.match-icon.pass .material-icons-outlined { color: var(--success); }
.match-icon.fail .material-icons-outlined { color: var(--error); }
.match-icon.warn .material-icons-outlined { color: var(--warning); }

@media (max-width: 900px) {
    .review-layout { grid-template-columns: 1fr; }
    .doc-compare { grid-template-columns: 1fr; }
    .entity-row { grid-template-columns: 1fr 1fr; gap: 8px; }
}
</style>
{% endblock %}

{% block content %}
<div class="content">
    <div class="page-header">
        <h1>Manual Review Queue</h1>
        <span class="badge yellow" style="font-size:0.9rem;padding:6px 14px">12 cases pending</span>
    </div>

    <div class="review-layout">
        <!-- Left: Case List -->
        <div class="case-list">
            <div class="case-list-header">
                <h3>Pending Cases</h3>
                <div class="content-search" style="margin-bottom:0">
                    <span class="material-icons-outlined">search</span>
                    <input type="text" placeholder="Search cases..." style="font-size:0.82rem">
                </div>
            </div>
            <div class="case-list-body">
                <div class="case-item active" onclick="selectCase(1)">
                    <div class="case-name">Jain Medical Agencies</div>
                    <div class="case-meta">GSTIN: 23AABCJ5432K1ZT &middot; Bhopal</div>
                    <div class="case-reason">Entity name mismatch (72% match)</div>
                </div>
                <div class="case-item" onclick="selectCase(2)">
                    <div class="case-name">Krishna Pharma Distributors</div>
                    <div class="case-meta">GSTIN: 29AABCK6789P1ZR &middot; Bangalore</div>
                    <div class="case-reason">Cancelled cheque name differs</div>
                </div>
                <div class="case-item" onclick="selectCase(3)">
                    <div class="case-name">Mehta Drug Agency</div>
                    <div class="case-meta">GSTIN: 24AABCM4321R1ZQ &middot; Surat</div>
                    <div class="case-reason">GSTIN certificate blurry</div>
                </div>
                <div class="case-item" onclick="selectCase(4)">
                    <div class="case-name">Saxena Medical House</div>
                    <div class="case-meta">GSTIN: 09AABCS1234T1ZN &middot; Agra</div>
                    <div class="case-reason">Bank account IFSC invalid</div>
                </div>
                <div class="case-item" onclick="selectCase(5)">
                    <div class="case-name">Roy Chemists Pvt Ltd</div>
                    <div class="case-meta">GSTIN: 19AABCR5678U1ZM &middot; Kolkata</div>
                    <div class="case-reason">Entity name mismatch (65% match)</div>
                </div>
                <div class="case-item" onclick="selectCase(6)">
                    <div class="case-name">Pillai Health Store</div>
                    <div class="case-meta">GSTIN: 32AABCP8901V1ZL &middot; Trivandrum</div>
                    <div class="case-reason">PAN not linked to GSTIN</div>
                </div>
                <div class="case-item" onclick="selectCase(7)">
                    <div class="case-name">Choudhary Pharma</div>
                    <div class="case-meta">GSTIN: 08AABCC2345W1ZK &middot; Jaipur</div>
                    <div class="case-reason">Cancelled cheque name differs</div>
                </div>
                <div class="case-item" onclick="selectCase(8)">
                    <div class="case-name">Das Medical Suppliers</div>
                    <div class="case-meta">GSTIN: 18AABCD6789X1ZJ &middot; Guwahati</div>
                    <div class="case-reason">Document expired</div>
                </div>
            </div>
        </div>

        <!-- Right: Detail View -->
        <div class="case-detail">
            <div class="detail-header">
                <div>
                    <h2>Jain Medical Agencies</h2>
                    <p style="color:var(--text-secondary);font-size:0.85rem;margin-top:4px">
                        GSTIN: 23AABCJ5432K1ZT &middot; Bhopal, Madhya Pradesh &middot; Submitted 25 Mar 2026
                    </p>
                </div>
                <div class="detail-actions">
                    <button class="btn btn-reject"><span class="material-icons-outlined">close</span> Reject</button>
                    <button class="btn btn-success"><span class="material-icons-outlined">check</span> Approve</button>
                </div>
            </div>

            <!-- Document Comparison -->
            <h3 style="margin-bottom:14px">Document Comparison</h3>
            <div class="doc-compare">
                <div class="doc-panel">
                    <div class="doc-panel-header">
                        <span class="material-icons-outlined" style="font-size:16px">description</span>
                        GSTIN Certificate
                    </div>
                    <div class="doc-panel-body">
                        <div class="doc-placeholder">
                            <span class="material-icons-outlined">article</span>
                            <p>GSTIN Certificate Image</p>
                            <p style="font-size:0.75rem;margin-top:4px">Entity: "Jain Medical Agencies Pvt Ltd"</p>
                        </div>
                    </div>
                </div>
                <div class="doc-panel">
                    <div class="doc-panel-header">
                        <span class="material-icons-outlined" style="font-size:16px">account_balance</span>
                        Cancelled Cheque
                    </div>
                    <div class="doc-panel-body">
                        <div class="doc-placeholder">
                            <span class="material-icons-outlined">account_balance</span>
                            <p>Cancelled Cheque Image</p>
                            <p style="font-size:0.75rem;margin-top:4px">Account: "Jain Medicals"</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Entity Name Comparison -->
            <h3 style="margin-bottom:14px">Entity Name Verification</h3>
            <div class="entity-compare">
                <div class="entity-row header">
                    <div>Field</div>
                    <div>GSTIN Certificate</div>
                    <div>Bank Records</div>
                    <div>Match</div>
                </div>
                <div class="entity-row">
                    <div style="font-weight:500;color:var(--text-secondary)">Legal Name</div>
                    <div>Jain Medical Agencies Pvt Ltd</div>
                    <div>Jain Medicals</div>
                    <div class="match-icon warn"><span class="material-icons-outlined">warning</span></div>
                </div>
                <div class="entity-row">
                    <div style="font-weight:500;color:var(--text-secondary)">PAN</div>
                    <div>AABCJ5432K</div>
                    <div>AABCJ5432K</div>
                    <div class="match-icon pass"><span class="material-icons-outlined">check_circle</span></div>
                </div>
                <div class="entity-row">
                    <div style="font-weight:500;color:var(--text-secondary)">Address</div>
                    <div>14, MG Road, Bhopal</div>
                    <div>14, M.G. Road, Bhopal</div>
                    <div class="match-icon pass"><span class="material-icons-outlined">check_circle</span></div>
                </div>
                <div class="entity-row">
                    <div style="font-weight:500;color:var(--text-secondary)">Match Score</div>
                    <div colspan="2" style="color:var(--warning);font-weight:600">72% -- Below 85% auto-approve threshold</div>
                    <div></div>
                    <div class="match-icon warn"><span class="material-icons-outlined">warning</span></div>
                </div>
            </div>

            <!-- Notes -->
            <div style="margin-top:20px">
                <h4 style="margin-bottom:8px">Review Notes</h4>
                <textarea style="width:100%;padding:12px;border:1px solid var(--grey);border-radius:8px;font-family:'Inter',sans-serif;font-size:0.88rem;resize:vertical;min-height:80px" placeholder="Add notes for this review decision..."></textarea>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
function selectCase(n) {
    document.querySelectorAll('.case-item').forEach(function(el, i) {
        el.classList.toggle('active', i === n - 1);
    });
}
</script>
{% endblock %}
