---
layout: base.njk
title: Retailer Onboarding
navActive: /09-retailer-wizard.html
permalink: /09-retailer-wizard.html
showSidebar: false
showTopbar: false
---
{% block headStyles %}
<style>
body { background: var(--canvas); display: block; min-height: 100vh; }
.main { margin-left: 0; min-height: 100vh; display: flex; flex-direction: column; }

/* ========== WIZARD SHELL ========== */
.wizard-topbar {
  background: var(--navy); padding: var(--sp-4) var(--sp-6);
  display: flex; align-items: center; gap: var(--sp-3);
}
.wizard-topbar svg { flex-shrink: 0; }
.wizard-brand { color: #fff; font-family: 'Kanit', sans-serif; font-weight: 700; font-size: 1.05rem; }
.wizard-brand small { display: block; font-weight: 400; font-size: 0.65rem; opacity: 0.55; font-family: 'Inter', sans-serif; }
.wizard-powered { margin-left: auto; font-size: 0.68rem; color: rgba(255,255,255,0.35); display: flex; align-items: center; gap: var(--sp-1); }
.wizard-powered span { color: rgba(255,255,255,0.65); font-weight: 600; }

/* ========== PROGRESS STEPPER ========== */
.stepper {
  background: var(--surface); padding: var(--sp-5) var(--sp-6); border-bottom: 1px solid var(--border);
  display: flex; align-items: center; justify-content: center; gap: 0;
}
.step-item { display: flex; align-items: center; gap: 0; }
.step-circle {
  width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center;
  font-family: 'Inter', sans-serif; font-weight: 700; font-size: 0.78rem; flex-shrink: 0;
  border: 1.5px solid var(--border-md); color: var(--muted); background: var(--surface); transition: all 0.2s ease;
}
.step-circle.active { border-color: var(--accent); color: #fff; background: var(--accent); }
.step-circle.done { border-color: var(--success); color: #fff; background: var(--success); }
.step-label { font-size: 0.68rem; font-weight: 600; color: var(--muted); margin-top: var(--sp-1); text-align: center; white-space: nowrap; text-transform: uppercase; letter-spacing: 0.03em; }
.step-label.active { color: var(--accent); }
.step-label.done { color: var(--success); }
.step-connector { width: 40px; height: 1.5px; background: var(--border-md); margin: 0 var(--sp-1); margin-bottom: 18px; transition: background 0.2s ease; }
.step-connector.done { background: var(--success); }
.step-col { display: flex; flex-direction: column; align-items: center; }

/* ========== WIZARD BODY ========== */
.wizard-body { flex: 1; display: flex; justify-content: center; padding: var(--sp-8) var(--sp-6); }
.wizard-card {
  background: var(--surface); border-radius: var(--radius-lg); border: 1px solid var(--border);
  width: 100%; max-width: 540px; padding: var(--sp-8) var(--sp-8);
}
.wizard-card h2 { font-size: 1.25rem; color: var(--ink); margin-bottom: var(--sp-1); }
.wizard-card .step-desc { font-size: 0.85rem; color: var(--faded); margin-bottom: var(--sp-6); line-height: 1.5; }

/* ========== FORM ELEMENTS ========== */
.form-group { margin-bottom: var(--sp-5); }
.form-label { display: block; font-weight: 600; font-size: 0.78rem; color: var(--ink); margin-bottom: var(--sp-1); }
.form-label .required { color: var(--error); }
.form-input {
  width: 100%; padding: var(--sp-3) var(--sp-3); border: 1px solid var(--border-md); border-radius: var(--radius-md);
  font-family: 'Inter', sans-serif; font-size: 0.85rem; outline: none; transition: border-color 0.15s ease;
  background: var(--canvas); color: var(--ink);
}
.form-input:focus { border-color: var(--accent); background: var(--surface); }
.form-input.success { border-color: var(--success); background: var(--success-light); }
.form-input.error { border-color: var(--error); background: var(--error-light); }
.form-hint { font-size: 0.72rem; color: var(--muted); margin-top: var(--sp-1); }
.form-error { font-size: 0.72rem; color: var(--error); margin-top: var(--sp-1); display: flex; align-items: center; gap: 3px; }
.form-error .material-icons-outlined { font-size: 13px; }
.form-success { font-size: 0.72rem; color: var(--success-dark); margin-top: var(--sp-1); display: flex; align-items: center; gap: 3px; }
.form-success .material-icons-outlined { font-size: 13px; }

.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-4); }

/* File upload */
.file-upload {
  border: 1.5px dashed var(--border-strong); border-radius: var(--radius-lg); padding: var(--sp-6); text-align: center;
  cursor: pointer; transition: all 0.15s ease; background: var(--canvas);
}
.file-upload:hover { border-color: var(--accent); background: var(--accent-light); }
.file-upload .material-icons-outlined { font-size: 28px; color: var(--muted); margin-bottom: var(--sp-2); }
.file-upload p { font-size: 0.82rem; color: var(--faded); }
.file-upload .formats { font-size: 0.7rem; color: var(--muted); margin-top: var(--sp-1); }
.file-upload.uploaded { border-color: var(--success); border-style: solid; background: var(--success-light); }
.file-upload.uploaded .material-icons-outlined { color: var(--success); }
.file-upload.uploaded p { color: var(--success-dark); font-weight: 600; }

/* ========== VERIFICATION STATUS CARDS ========== */
.verify-card {
  border-radius: var(--radius-lg); padding: var(--sp-4); margin-bottom: var(--sp-3);
  display: flex; align-items: flex-start; gap: var(--sp-3);
}
.verify-card.pending { background: var(--warning-light); border: 1px solid rgba(245,158,11,0.2); }
.verify-card.running { background: var(--accent-light); border: 1px solid rgba(21,155,215,0.15); }
.verify-card.success { background: var(--success-light); border: 1px solid rgba(16,185,129,0.2); }
.verify-card.failed { background: var(--error-light); border: 1px solid rgba(239,68,68,0.2); }
.verify-icon {
  width: 36px; height: 36px; border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.verify-card.pending .verify-icon { background: rgba(245,158,11,0.15); color: #D97706; }
.verify-card.running .verify-icon { background: rgba(21,155,215,0.15); color: var(--accent); }
.verify-card.success .verify-icon { background: rgba(16,185,129,0.15); color: var(--success-dark); }
.verify-card.failed .verify-icon { background: rgba(239,68,68,0.15); color: #DC2626; }
.verify-icon .material-icons-outlined { font-size: 20px; }
.verify-title { font-weight: 600; font-size: 0.82rem; color: var(--ink); margin-bottom: 1px; }
.verify-detail { font-size: 0.78rem; color: var(--faded); line-height: 1.4; }
.verify-card.success .verify-detail { color: var(--success-dark); }
.verify-card.failed .verify-detail { color: #DC2626; }

/* Spinner */
.verify-spinner {
  width: 20px; height: 20px; border: 2px solid var(--accent-light);
  border-top-color: var(--accent); border-radius: 50%; animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* Name match bar */
.match-bar-wrap { margin-top: var(--sp-2); }
.match-bar-label { display: flex; justify-content: space-between; font-size: 0.72rem; margin-bottom: var(--sp-1); }
.match-bar-label span:first-child { color: var(--faded); }
.match-bar-label span:last-child { font-weight: 700; }
.match-bar { height: 6px; background: var(--border-md); border-radius: 3px; overflow: hidden; }
.match-bar-fill { height: 100%; border-radius: 3px; transition: width 1s ease; }
.match-bar-fill.high { background: var(--success); }
.match-bar-fill.mid { background: var(--warning); }
.match-bar-fill.low { background: var(--error); }

/* ========== NAME COMPARISON TABLE ========== */
.name-compare { border: 1px solid var(--border); border-radius: var(--radius-md); overflow: hidden; margin-top: var(--sp-3); }
.name-compare-row { display: flex; padding: var(--sp-2) var(--sp-3); font-size: 0.78rem; border-bottom: 1px solid var(--border); }
.name-compare-row:last-child { border-bottom: none; }
.name-compare-row .ncr-label { width: 110px; font-weight: 600; color: var(--faded); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.03em; flex-shrink: 0; }
.name-compare-row .ncr-value { flex: 1; font-weight: 500; color: var(--ink); }
.name-compare-header { background: var(--canvas); font-weight: 700; }

/* ========== BUTTONS ========== */
.wizard-actions { display: flex; gap: var(--sp-3); margin-top: var(--sp-6); }
.wizard-actions .btn { flex: 1; justify-content: center; padding: var(--sp-3); font-size: 0.88rem; border-radius: var(--radius-md); }
.btn-back { background: transparent; border: 1px solid var(--border-md); color: var(--ink); }
.btn-back:hover { border-color: var(--border-strong); }

/* ========== CONFIRMATION PAGE ========== */
.confirm-hero { text-align: center; padding: var(--sp-5) 0; }
.confirm-icon {
  width: 72px; height: 72px; border-radius: 50%; margin: 0 auto var(--sp-5);
  display: flex; align-items: center; justify-content: center;
  background: var(--success-light);
}
.confirm-icon .material-icons-outlined { font-size: 40px; color: var(--success); }
.confirm-hero h2 { color: var(--success-dark); margin-bottom: var(--sp-2); }
.confirm-hero p { color: var(--faded); font-size: 0.88rem; line-height: 1.6; max-width: 400px; margin: 0 auto; }
.confirm-details {
  background: var(--canvas); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: var(--sp-5); margin-top: var(--sp-6);
}
.confirm-row { display: flex; justify-content: space-between; padding: var(--sp-2) 0; font-size: 0.82rem; border-bottom: 1px solid var(--border); }
.confirm-row:last-child { border-bottom: none; }
.confirm-row .cr-label { color: var(--faded); }
.confirm-row .cr-value { font-weight: 600; color: var(--ink); }

/* ========== RESPONSIVE ========== */
@media (max-width: 600px) {
  .wizard-card { padding: var(--sp-5); }
  .stepper { padding: var(--sp-4) var(--sp-3); }
  .step-connector { width: 20px; }
  .step-label { font-size: 0.6rem; }
  .form-row { grid-template-columns: 1fr; }
  .wizard-actions { flex-direction: column; }
}
</style>
{% endblock %}

{% block content %}
<!-- WIZARD TOP BAR -->
<div class="wizard-topbar">
  <svg width="32" height="32" viewBox="-5 -5 92 78" fill="none">
    <g transform="translate(-635.84274,-750.91924)">
      <path fill="#3BB5E8" d="m 708.91763,751.91925 h -72.07462 v 11.07625 h 68.47655 v 0.01 c 1.98226,0 3.565,1.58961 3.565,3.56314 v 37.19433 l -0.009,0.0315 c -0.0122,1.96479 -1.61079,3.54383 -3.57188,3.54383 h -53.81334 c -1.97009,0 -3.58246,-1.59174 -3.58246,-3.57558 v -15.02596 c 0,-1.97352 1.61237,-3.57557 3.58246,-3.57557 h 46.29759 v -11.06144 h -49.90121 c -6.09944,0 -11.04398,4.93554 -11.04398,11.03074 v 22.23903 c 0,6.09944 4.94454,11.04212 11.04398,11.04212 h 61.03064 c 6.10473,0 11.04212,-4.94268 11.04212,-11.04212 v -44.40449 c 0,-6.09865 -4.93739,-11.04556 -11.04212,-11.04556"/>
    </g>
  </svg>
  <div class="wizard-brand">Abbott India<small>Retailer Reward Program</small></div>
  <div class="wizard-powered">Powered by <span>Engage</span></div>
</div>

<!-- PROGRESS STEPPER -->
<div class="stepper" id="stepper">
  <div class="step-col">
    <div class="step-circle active" id="sc1">1</div>
    <div class="step-label active">GSTIN</div>
  </div>
  <div class="step-connector"></div>
  <div class="step-col">
    <div class="step-circle" id="sc2">2</div>
    <div class="step-label">Documents</div>
  </div>
  <div class="step-connector"></div>
  <div class="step-col">
    <div class="step-circle" id="sc3">3</div>
    <div class="step-label">Bank Details</div>
  </div>
  <div class="step-connector"></div>
  <div class="step-col">
    <div class="step-circle" id="sc4">4</div>
    <div class="step-label">Verification</div>
  </div>
  <div class="step-connector"></div>
  <div class="step-col">
    <div class="step-circle" id="sc5">5</div>
    <div class="step-label">Confirmation</div>
  </div>
</div>

<!-- WIZARD BODY -->
<div class="wizard-body">
  <!-- ==================== STEP 1: GSTIN ==================== -->
  <div class="wizard-card" id="step1">
    <h2>GSTIN Verification</h2>
    <p class="step-desc">Enter your GSTIN number to verify your business identity with Abbott India's Reward Program.</p>

    <div class="form-group">
      <label class="form-label">GSTIN Number <span class="required">*</span></label>
      <input type="text" class="form-input" placeholder="e.g., 27AABCU9603R1ZP" maxlength="15" value="" id="gstinInput">
      <div class="form-hint">15-character alphanumeric GST Identification Number</div>
    </div>

    <div class="form-group">
      <label class="form-label">Registered Phone Number <span class="required">*</span></label>
      <input type="tel" class="form-input" placeholder="e.g., 9876543210" maxlength="10" value="">
      <div class="form-hint">Must match the phone number provided by Abbott</div>
    </div>

    <div class="wizard-actions">
      <button class="btn btn-primary" onclick="goToStep(2)">
        Verify GSTIN <span class="material-icons-outlined">arrow_forward</span>
      </button>
    </div>
  </div>

  <!-- ==================== STEP 2: DOCUMENTS ==================== -->
  <div class="wizard-card" id="step2" style="display:none;">
    <h2>Upload Documents</h2>
    <p class="step-desc">Upload your GST certificate and cancelled cheque for identity verification.</p>

    <div class="form-group">
      <label class="form-label">GST Certificate <span class="required">*</span></label>
      <div class="file-upload uploaded">
        <span class="material-icons-outlined">task</span>
        <p>GST_Certificate_27AAPFS5235K1Z8.pdf</p>
        <div class="formats">Uploaded successfully - 1.2 MB</div>
      </div>
    </div>

    <div class="form-group">
      <label class="form-label">Cancelled Cheque <span class="required">*</span></label>
      <div class="file-upload uploaded">
        <span class="material-icons-outlined">task</span>
        <p>Cancelled_Cheque_HDFC.jpg</p>
        <div class="formats">Uploaded successfully - 856 KB</div>
      </div>
    </div>

    <div class="wizard-actions">
      <button class="btn btn-back" onclick="goToStep(1)">
        <span class="material-icons-outlined">arrow_back</span> Back
      </button>
      <button class="btn btn-primary" onclick="goToStep(3)">
        Continue <span class="material-icons-outlined">arrow_forward</span>
      </button>
    </div>
  </div>

  <!-- ==================== STEP 3: BANK DETAILS ==================== -->
  <div class="wizard-card" id="step3" style="display:none;">
    <h2>Bank Account Details</h2>
    <p class="step-desc">Enter your bank account details. Rewards will be transferred directly to this account via IMPS.</p>

    <div class="form-group">
      <label class="form-label">Account Holder Name <span class="required">*</span></label>
      <input type="text" class="form-input success" value="SHARMA MEDICAL STORE">
      <div class="form-success"><span class="material-icons-outlined">check_circle</span> Name auto-filled from cancelled cheque</div>
    </div>

    <div class="form-group">
      <label class="form-label">Bank Account Number <span class="required">*</span></label>
      <input type="text" class="form-input" value="50100268745123" placeholder="Enter account number">
    </div>

    <div class="form-group">
      <label class="form-label">Confirm Account Number <span class="required">*</span></label>
      <input type="text" class="form-input success" value="50100268745123">
      <div class="form-success"><span class="material-icons-outlined">check_circle</span> Account numbers match</div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label class="form-label">IFSC Code <span class="required">*</span></label>
        <input type="text" class="form-input" value="HDFC0001234" maxlength="11" placeholder="e.g., HDFC0001234">
      </div>
      <div class="form-group">
        <label class="form-label">Bank Name</label>
        <input type="text" class="form-input" value="HDFC Bank" disabled style="opacity:0.6;">
        <div class="form-hint">Auto-detected from IFSC</div>
      </div>
    </div>

    <div class="form-group">
      <label class="form-label">PAN Number (Recommended)</label>
      <input type="text" class="form-input" value="AAPFS5235K" maxlength="10" placeholder="e.g., ABCDE1234F">
      <div class="form-hint" style="color:var(--warning);font-weight:500;">Providing PAN linked with Aadhaar reduces your TDS from 20% to 10%. Without PAN or if PAN is not linked with Aadhaar, TDS will be 20% on rewards above &#8377;20,000/year.</div>
    </div>

    <div class="wizard-actions">
      <button class="btn btn-back" onclick="goToStep(2)">
        <span class="material-icons-outlined">arrow_back</span> Back
      </button>
      <button class="btn btn-primary" onclick="goToStep(4)">
        Verify Account <span class="material-icons-outlined">arrow_forward</span>
      </button>
    </div>
  </div>

  <!-- ==================== STEP 4: VERIFICATION ==================== -->
  <div class="wizard-card" id="step4" style="display:none;">
    <h2>Verification in Progress</h2>
    <p class="step-desc">We are verifying your details against government and banking databases. This usually takes less than 30 seconds.</p>

    <!-- Check 1: GSTIN Verification -->
    <div class="verify-card success">
      <div class="verify-icon"><span class="material-icons-outlined">verified</span></div>
      <div>
        <div class="verify-title">GSTIN Verification</div>
        <div class="verify-detail">GSTIN 27AAPFS5235K1Z8 is active. Trade name: SHARMA MEDICAL STORE</div>
      </div>
    </div>

    <!-- Check 2: Bank Account Verification (Penny Drop) -->
    <div class="verify-card success">
      <div class="verify-icon"><span class="material-icons-outlined">account_balance</span></div>
      <div>
        <div class="verify-title">Bank Account Verification (Penny Drop)</div>
        <div class="verify-detail">Account verified. Holder: SHARMA MEDICAL STORE. Ref: PD20260401-48291</div>
      </div>
    </div>

    <!-- Check 3: PAN Verification -->
    <div class="verify-card success">
      <div class="verify-icon"><span class="material-icons-outlined">badge</span></div>
      <div>
        <div class="verify-title">PAN Verification</div>
        <div class="verify-detail">PAN AAPFS5235K is valid and operative. PAN type: <strong>Individual (Proprietorship)</strong>. Name: RAMESH KUMAR SHARMA</div>
      </div>
    </div>

    <!-- Check 4: PAN-Aadhaar Link Check -->
    <div class="verify-card success">
      <div class="verify-icon"><span class="material-icons-outlined">link</span></div>
      <div>
        <div class="verify-title">PAN-Aadhaar Link Verification</div>
        <div class="verify-detail">PAN is linked with Aadhaar. PAN status: Operative. TDS bracket: 10%</div>
      </div>
    </div>

    <!-- Check 5: Entity Name Matching (PAN-type aware) -->
    <div class="verify-card success">
      <div class="verify-icon"><span class="material-icons-outlined">compare_arrows</span></div>
      <div style="flex:1;">
        <div class="verify-title">Entity-to-Bank Verification</div>
        <div class="verify-detail">Constitution: Proprietorship -- matching bank account name against proprietor name (PAN)</div>
        <div class="name-compare">
          <div class="name-compare-row name-compare-header">
            <div class="ncr-label">Source</div>
            <div class="ncr-value">Entity / Holder Name</div>
          </div>
          <div class="name-compare-row">
            <div class="ncr-label">GSTIN (Trade)</div>
            <div class="ncr-value">SHARMA MEDICAL STORE</div>
          </div>
          <div class="name-compare-row">
            <div class="ncr-label">PAN (Proprietor)</div>
            <div class="ncr-value" style="font-weight:600;">RAMESH KUMAR SHARMA</div>
          </div>
          <div class="name-compare-row">
            <div class="ncr-label">Bank (Penny Drop)</div>
            <div class="ncr-value" style="font-weight:600;">RAMESH K SHARMA</div>
          </div>
        </div>
        <div style="font-size:0.68rem; color:var(--faded); margin-top:var(--sp-2); padding:var(--sp-2) var(--sp-3); background:var(--canvas); border-radius:var(--radius-sm);">
          <span class="material-icons-outlined" style="font-size:12px; vertical-align:middle;">info</span>
          PAN type is Individual -- using proprietor name (PAN) for bank name matching instead of GSTIN trade name
        </div>
        <div class="match-bar-wrap">
          <div class="match-bar-label">
            <span>Name Match Score (PAN vs Bank)</span>
            <span style="color:var(--success-dark);">91%</span>
          </div>
          <div class="match-bar">
            <div class="match-bar-fill high" style="width:91%;"></div>
          </div>
          <div style="font-size:0.68rem; color:var(--success-dark); margin-top:var(--sp-1);">Threshold: 70% (Proprietorship) -- Match successful</div>
        </div>
      </div>
    </div>

    <!-- Check 6: Duplicate Check -->
    <div class="verify-card running" id="duplicateCheck">
      <div class="verify-icon"><div class="verify-spinner"></div></div>
      <div>
        <div class="verify-title">Duplicate Registration Check</div>
        <div class="verify-detail">Checking if GSTIN is already registered in the system...</div>
      </div>
    </div>

    <div class="wizard-actions">
      <button class="btn btn-back" onclick="goToStep(3)">
        <span class="material-icons-outlined">arrow_back</span> Back
      </button>
      <button class="btn btn-primary" id="verifyNextBtn" onclick="completeDuplicateCheck()">
        <span class="material-icons-outlined" style="font-size:16px;">hourglass_top</span> Verifying...
      </button>
    </div>
  </div>

  <!-- ==================== STEP 5: CONFIRMATION ==================== -->
  <div class="wizard-card" id="step5" style="display:none;">
    <div class="confirm-hero">
      <div class="confirm-icon">
        <span class="material-icons-outlined">check_circle</span>
      </div>
      <h2>Verification Complete</h2>
      <p>You are now part of the Abbott India Retailer Reward Program. Rewards will be transferred directly to your verified bank account.</p>
    </div>

    <div class="confirm-details">
      <div class="confirm-row">
        <span class="cr-label">Trade Name</span>
        <span class="cr-value">Sharma Medical Store</span>
      </div>
      <div class="confirm-row">
        <span class="cr-label">Proprietor</span>
        <span class="cr-value">Ramesh Kumar Sharma</span>
      </div>
      <div class="confirm-row">
        <span class="cr-label">Constitution</span>
        <span class="cr-value">Proprietorship</span>
      </div>
      <div class="confirm-row">
        <span class="cr-label">GSTIN</span>
        <span class="cr-value">27AAPFS5235K1Z8</span>
      </div>
      <div class="confirm-row">
