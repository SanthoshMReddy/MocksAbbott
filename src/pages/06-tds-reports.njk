{% block headStyles %}
<style>
.fy-selector { display: flex; align-items: center; gap: 12px; margin-bottom: 24px; }
.fy-selector select {
    padding: 8px 14px; border: 1px solid var(--grey); border-radius: 8px;
    font-family: 'Inter', sans-serif; font-size: 0.9rem; background: var(--white);
}

.quarter-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 28px; }
.quarter-card {
    background: var(--white); border: 1px solid #E5E7EB; border-radius: 12px; padding: 20px;
    text-align: center;
}
.quarter-card.active { border-color: var(--blue); box-shadow: 0 0 0 2px rgba(21,155,215,0.15); }
.quarter-card h4 { font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 8px; }
.quarter-card .q-amount { font-family: 'Kanit', sans-serif; font-weight: 700; font-size: 1.4rem; color: var(--text-primary); }
.quarter-card .q-count { font-size: 0.78rem; color: var(--text-secondary); margin-top: 4px; }

.export-bar { display: flex; gap: 12px; margin-bottom: 24px; }

@media (max-width: 768px) { .quarter-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 480px) { .quarter-grid { grid-template-columns: 1fr; } }
</style>
{% endblock %}

{% block content %}
<div class="content">
    <div class="page-header">
        <h1>TDS Reports</h1>
        <div class="export-bar">
            <button class="btn btn-primary">
                <span class="material-icons-outlined">download</span> Export Form 26Q
            </button>
            <button class="btn btn-outline">
                <span class="material-icons-outlined">summarize</span> TDS Certificate
            </button>
        </div>
    </div>

    <!-- FY Selector -->
    <div class="fy-selector">
        <span style="font-weight:600;font-size:0.9rem">Financial Year:</span>
        <select>
            <option selected>FY 2025-26</option>
            <option>FY 2024-25</option>
        </select>
        <span style="font-size:0.85rem;color:var(--text-secondary)">Section 194R &middot; Threshold: &#8377;15,000</span>
