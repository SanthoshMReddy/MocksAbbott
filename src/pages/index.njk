{% block scripts %}
<script>
function applyTheme(name) {
    // Swap CSS file
    document.getElementById('theme-css-link').href = '/assets/themes/' + name + '.css?v=' + Date.now();
    // Swap CSS variables via data-theme attribute
    document.documentElement.setAttribute('data-theme', name);
    // Persist choice
    localStorage.setItem('mockup-theme', name);
    // Update active state in picker
    document.querySelectorAll('.theme-option').forEach(function(el) {
        el.classList.toggle('active', el.getAttribute('data-theme') === name);
    });
    // Close picker after a short delay
    setTimeout(closeThemePicker, 300);
}

function openThemePicker() {
    var overlay = document.getElementById('themeOverlay');
    overlay.classList.add('visible');
    // Highlight current theme
    var current = localStorage.getItem('mockup-theme') || '{{ site.theme | default("clinical") }}';
    document.querySelectorAll('.theme-option').forEach(function(el) {
        el.classList.toggle('active', el.getAttribute('data-theme') === current);
    });
}

function closeThemePicker() {
    document.getElementById('themeOverlay').classList.remove('visible');
}

document.addEventListener('keydown', function(e) {
    // Ignore if typing in an input
    if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;

    if (e.key === 'e' || e.key === 'E') {
        var overlay = document.getElementById('themeOverlay');
        if (overlay.classList.contains('visible')) {
            closeThemePicker();
        } else {
            openThemePicker();
        }
    }
    if (e.key === 'Escape') {
        closeThemePicker();
    }
});
</script>
{% endblock %}
