---
layout: base.njk
title: Mockups
showSidebar: false
showTopbar: false
permalink: /index.html
---
{% block headStyles %}
<style>
body { background: var(--canvas); display: block; min-height: auto; }
.main { margin-left: 0; min-height: auto; }

.hero {
    background: var(--navy);
    padding: 64px 32px 56px;
    text-align: center;
}
.hero-logo { display: inline-block; margin-bottom: 24px; }
.hero-tagline {
    font-family: 'Kanit', sans-serif;
    font-weight: 700;
    font-size: 1.5rem;
    color: var(--accent);
    margin-bottom: 12px;
}
.hero-description {
    color: rgba(255,255,255,0.6);
    font-size: 0.95rem;
    max-width: 560px;
    margin: 0 auto 24px;
}
.hero-accent {
    display: inline-block;
    width: 40px; height: 3px;
    background: var(--success);
    border-radius: 2px;
}

.cards-section {
    max-width: 1100px;
    margin: 0 auto;
    padding: 48px 32px 64px;
}
.section-heading {
    font-family: 'Kanit', sans-serif;
    font-weight: 700;
    font-size: 1.25rem;
    margin-bottom: 28px;
    text-align: center;
}
.cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
}
.screen-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px 24px 24px;
    display: flex; flex-direction: column;
    transition: all 0.15s ease;
    text-decoration: none;
    color: var(--ink);
    position: relative; overflow: hidden;
}
.screen-card:hover {
    border-color: var(--accent);
    transform: translateY(-1px);
    text-decoration: none;
}
.card-icon-wrap {
    width: 48px; height: 48px;
    border-radius: var(--radius-lg);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 16px;
}
.card-icon-wrap .material-icons-outlined { font-size: 24px; color: #fff; }
.card-icon-wrap.blue { background: var(--accent); }
.card-icon-wrap.purple { background: var(--purple); }
.card-icon-wrap.green { background: var(--success); }
.card-icon-wrap.dark { background: var(--navy); }
.card-icon-wrap.teal { background: var(--teal); }
.card-icon-wrap.warning { background: var(--warning); }
.card-icon-wrap.pink { background: var(--pink); }
.card-icon-wrap.error { background: var(--error); }
.screen-card h3 { font-weight: 700; font-size: 1.05rem; margin-bottom: 8px; }
.screen-card p { font-size: 0.85rem; color: var(--faded); line-height: 1.5; flex: 1; }
.screen-card .card-number {
    position: absolute; top: 16px; right: 18px;
    font-family: 'Kanit', sans-serif; font-weight: 800;
    font-size: 2rem; color: rgba(15,23,41,0.04);
}
.footer {
    text-align: center; padding: 24px;
    font-size: 0.8rem; color: var(--muted);
    border-top: 1px solid var(--border);
}

@media (max-width: 900px) { .cards-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 600px) { .cards-grid { grid-template-columns: 1fr; max-width: 400px; margin: 0 auto; } }

/* Theme Picker (hidden by default) */
.theme-overlay {
    display: none; position: fixed; inset: 0; z-index: 9999;
    background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);
    align-items: center; justify-content: center;
}
.theme-overlay.visible { display: flex; }
.theme-picker {
    background: #fff; border-radius: 16px; padding: 32px;
    width: 90%; max-width: 640px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.2);
    animation: pickerIn 0.2s ease;
}
@keyframes pickerIn { from { opacity: 0; transform: scale(0.95) translateY(10px); } to { opacity: 1; transform: none; } }
.theme-picker h3 { font-family: 'Inter', sans-serif; font-weight: 700; font-size: 1.1rem; margin-bottom: 4px; color: #1A1A1A; }
.theme-picker .picker-desc { font-size: 0.82rem; color: #6B7280; margin-bottom: 24px; }
.theme-options { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
.theme-option {
    border: 2px solid #E5E7EB; border-radius: 12px; padding: 20px 16px;
    cursor: pointer; transition: all 0.15s ease; text-align: center;
    background: #fff;
}
.theme-option:hover { border-color: #159BD7; background: #F8FBFF; }
.theme-option.active { border-color: #159BD7; background: #EFF8FD; box-shadow: 0 0 0 3px rgba(21,155,215,0.15); }
.theme-option .to-icon { font-size: 28px; margin-bottom: 8px; display: block; }
.theme-option .to-name { font-weight: 700; font-size: 0.88rem; color: #1A1A1A; margin-bottom: 4px; }
.theme-option .to-desc { font-size: 0.7rem; color: #6B7280; line-height: 1.4; }
.theme-picker .picker-hint {
    margin-top: 20px; text-align: center;
    font-size: 0.72rem; color: #9CA3AF;
}
.theme-picker .picker-hint kbd {
    display: inline-block; padding: 1px 6px; border: 1px solid #D1D5DB;
    border-radius: 4px; font-family: monospace; font-size: 0.7rem;
    background: #F9FAFB; color: #6B7280;
}
</style>
{% endblock %}

