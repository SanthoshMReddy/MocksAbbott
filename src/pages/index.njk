<!-- Hidden Theme Picker (press E to reveal) -->
<div class="theme-overlay" id="themeOverlay" onclick="if(event.target===this)closeThemePicker()">
    <div class="theme-picker">
        <h3>Switch Design Theme</h3>
        <p class="picker-desc">Choose a design style. All pages will update instantly.</p>
        <div class="theme-options">
            <div class="theme-option" data-theme="clinical" onclick="applyTheme('clinical')">
                <span class="to-icon material-icons-outlined">straighten</span>
                <div class="to-name">Clinical</div>
                <div class="to-desc">Borders-only, cool palette, left-accent stat cards</div>
            </div>
            <div class="theme-option" data-theme="glassmorphism" onclick="applyTheme('glassmorphism')">
                <span class="to-icon material-icons-outlined">blur_on</span>
                <div class="to-name">Glassmorphism</div>
                <div class="to-desc">Frosted glass, backdrop blur, colored glow</div>
            </div>
            <div class="theme-option" data-theme="neo-brutalist" onclick="applyTheme('neo-brutalist')">
                <span class="to-icon material-icons-outlined">crop_square</span>
                <div class="to-name">Neo-Brutalist</div>
                <div class="to-desc">Thick borders, offset shadows, bold typography</div>
            </div>
        </div>
        <div class="picker-hint">Press <kbd>E</kbd> to toggle &middot; Press <kbd>Esc</kbd> to close</div>
    </div>
</div>
