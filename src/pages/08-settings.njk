---
layout: base.njk
title: Settings
navActive: /08-settings.html
permalink: /08-settings.html
---
{% block headStyles %}
<style>
.settings-layout { display: grid; grid-template-columns: 200px 1fr; gap: var(--sp-5); }

.settings-tabs { background: var(--surface); border-radius: var(--radius-lg); border: 1px solid var(--border); padding: var(--sp-2) 0; height: fit-content; }
.settings-tab {
    display: flex; align-items: center; gap: var(--sp-2); padding: var(--sp-2) var(--sp-5);
    font-size: 0.82rem; font-weight: 500; color: var(--faded);
    cursor: pointer; transition: all 0.12s ease; border-left: 2px solid transparent;
}
.settings-tab:hover { background: var(--canvas); color: var(--ink); }
.settings-tab.active { border-left-color: var(--accent); background: var(--accent-light); color: var(--accent); font-weight: 600; }
.settings-tab .material-icons-outlined { font-size: 18px; }

.settings-panel { background: var(--surface); border-radius: var(--radius-lg); border: 1px solid var(--border); padding: var(--sp-6); }
.settings-panel h2 { margin-bottom: var(--sp-2); }
.settings-panel .panel-desc { font-size: 0.78rem; color: var(--faded); margin-bottom: var(--sp-6); }

.form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-5); }
.form-group { margin-bottom: var(--sp-4); }
.form-group label {
    display: block; font-size: 0.75rem; font-weight: 600;
    color: var(--faded); margin-bottom: var(--sp-1); text-transform: uppercase; letter-spacing: 0.03em;
}
.form-group input, .form-group select, .form-group textarea {
    width: 100%; padding: var(--sp-2) var(--sp-3); border: 1px solid var(--border-md);
    border-radius: var(--radius-md); font-family: 'Inter', sans-serif; font-size: 0.85rem;
    background: var(--canvas); color: var(--ink);
}
.form-group input:focus, .form-group select:focus, .form-group textarea:focus {
    outline: none; border-color: var(--accent);
}
.form-group .help-text { font-size: 0.7rem; color: var(--muted); margin-top: var(--sp-1); }

.form-divider { height: 1px; background: var(--border); margin: var(--sp-6) 0; }

.toggle-row { display: flex; align-items: center; justify-content: space-between; padding: var(--sp-3) 0; border-bottom: 1px solid var(--border); }
.toggle-row:last-child { border-bottom: none; }
.toggle-label { font-weight: 500; font-size: 0.85rem; }
.toggle-desc { font-size: 0.72rem; color: var(--muted); margin-top: 1px; }
.toggle-switch {
    width: 40px; height: 22px; border-radius: 11px; background: var(--border-strong);
    position: relative; cursor: pointer; transition: background 0.15s ease;
}
.toggle-switch.on { background: var(--accent); }
.toggle-switch::after {
    content: ''; position: absolute; top: 2px; left: 2px;
    width: 18px; height: 18px; border-radius: 50%; background: #fff;
    transition: left 0.15s ease;
}
.toggle-switch.on::after { left: 20px; }

@media (max-width: 768px) {
    .settings-layout { grid-template-columns: 1fr; }
    .form-grid { grid-template-columns: 1fr; }
}
</style>
{% endblock %}

{% block content %}
<div class="content">
    <div class="page-header">
        <h1>Settings</h1>
        <button class="btn btn-primary">
            <span class="material-icons-outlined">save</span> Save Changes
        </button>
    </div>

    <div class="settings-layout">
        <!-- Left: Tabs -->
        <div class="settings-tabs">
            <div class="settings-tab active" onclick="switchSettingsTab('kyc')">
                <span class="material-icons-outlined">verified_user</span> KYC Config
            </div>
            <div class="settings-tab" onclick="switchSettingsTab('tds')">
                <span class="material-icons-outlined">receipt_long</span> TDS Config
            </div>
            <div class="settings-tab" onclick="switchSettingsTab('payout')">
                <span class="material-icons-outlined">payments</span> Payout Config
            </div>
            <div class="settings-tab" onclick="switchSettingsTab('wallet')">
                <span class="material-icons-outlined">account_balance_wallet</span> Wallet Config
            </div>
            <div class="settings-tab" onclick="switchSettingsTab('notifications')">
                <span class="material-icons-outlined">notifications</span> Notifications
            </div>
        </div>

        <!-- Right: Panel -->
        <div>
            <!-- KYC Config Panel -->
            <div class="settings-panel" id="panel-kyc">
                <h2>KYC Configuration</h2>
                <p class="panel-desc">Configure retailer verification settings for the Abbott Engage program.</p>

                <div class="form-grid">
                    <div class="form-group">
                        <label>Entity Name Match Threshold (%)</label>
                        <input type="number" value="85" min="50" max="100">
                        <div class="help-text">Auto-approve if name match score is above this threshold</div>
                    </div>
                    <div class="form-group">
                        <label>KYC Link Expiry (hours)</label>
                        <input type="number" value="72">
                        <div class="help-text">Retailer KYC link expires after this duration</div>
                    </div>
                    <div class="form-group">
                        <label>Maximum KYC Retries</label>
                        <input type="number" value="3">
                        <div class="help-text">Number of attempts before manual review required</div>
                    </div>
                    <div class="form-group">
                        <label>Verification Provider</label>
                        <select>
                            <option selected>Surepass API</option>
                            <option>Gridlines API</option>
                            <option>Deepvue API</option>
                            <option>Custom Integration</option>
                        </select>
                    </div>
                </div>

                <div class="form-divider"></div>
                <h3 style="margin-bottom:var(--sp-4)">Verification Toggles</h3>

                <div class="toggle-row">
                    <div>
                        <div class="toggle-label">GSTIN Verification</div>
                        <div class="toggle-desc">Verify retailer GSTIN against GST portal</div>
                    </div>
                    <div class="toggle-switch on" onclick="this.classList.toggle('on')"></div>
                </div>
                <div class="toggle-row">
                    <div>
                        <div class="toggle-label">Bank Account Verification</div>
                        <div class="toggle-desc">Verify bank account via penny drop</div>
                    </div>
                    <div class="toggle-switch on" onclick="this.classList.toggle('on')"></div>
                </div>
                <div class="toggle-row">
                    <div>
                        <div class="toggle-label">PAN Verification</div>
                        <div class="toggle-desc">Validate PAN number against NSDL database</div>
                    </div>
                    <div class="toggle-switch on" onclick="this.classList.toggle('on')"></div>
                </div>
                <div class="toggle-row">
                    <div>
                        <div class="toggle-label">PAN-Aadhaar Link Check</div>
                        <div class="toggle-desc">Verify PAN is linked with Aadhaar (operative status). Inoperative PAN triggers 20% TDS.</div>
                    </div>
                    <div class="toggle-switch on" onclick="this.classList.toggle('on')"></div>
                </div>
                <div class="toggle-row">
                    <div>
                        <div class="toggle-label">Cancelled Cheque Required</div>
                        <div class="toggle-desc">Require cancelled cheque upload for bank verification</div>
                    </div>
                    <div class="toggle-switch" onclick="this.classList.toggle('on')"></div>
                </div>
            </div>

            <!-- TDS Config Panel (hidden) -->
            <div class="settings-panel" id="panel-tds" style="display:none">
                <h2>TDS Configuration</h2>
                <p class="panel-desc">Tax Deducted at Source settings under Section 194R of the Income Tax Act.</p>

                <div class="form-grid">
                    <div class="form-group">
                        <label>TDS Section</label>
                        <select>
                            <option selected>194R - Benefits/Perquisites (Business)</option>
                            <option>194R - Alternate</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Annual Threshold (&#8377;)</label>
                        <input type="number" value="20000">
                        <div class="help-text">TDS applicable when cumulative payout exceeds this amount per FY. TDS applies on FULL amount once crossed.</div>
                    </div>
                    <div class="form-group">
                        <label>TDS Rate - PAN Operative (%)</label>
                        <input type="number" value="10" step="0.1">
                        <div class="help-text">PAN valid and linked with Aadhaar (Section 194R standard rate)</div>
                    </div>
                    <div class="form-group">
                        <label>TDS Rate - PAN Inoperative / No PAN (%)</label>
                        <input type="number" value="20" step="0.1">
                        <div class="help-text">Section 206AA: PAN not furnished or not linked with Aadhaar</div>
                    </div>
                </div>
            </div>

            <!-- Payout Config Panel (hidden) -->
            <div class="settings-panel" id="panel-payout" style="display:none">
                <h2>Payout Configuration</h2>
                <p class="panel-desc">Settings for retailer reward payout processing via IMPS.</p>

                <div class="form-grid">
                    <div class="form-group">
                        <label>OTP Expiry (minutes)</label>
                        <input type="number" value="10">
                    </div>
                    <div class="form-group">
                        <label>Maximum OTP Retries</label>
                        <input type="number" value="3">
                    </div>
                    <div class="form-group">
                        <label>Payout Link Expiry (hours)</label>
                        <input type="number" value="48">
                        <div class="help-text">Retailer must claim payout within this window</div>
                    </div>
                    <div class="form-group">
                        <label>Maximum Batch Size (rows)</label>
                        <input type="number" value="10000">
                    </div>
                    <div class="form-group">
                        <label>IMPS Transfer Mode</label>
                        <select>
                            <option selected>IMPS (Instant)</option>
                            <option>NEFT (Batch)</option>
                            <option>UPI</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Auto-Retry Failed Transfers</label>
                        <select>
                            <option selected>Yes (up to 2 retries)</option>
                            <option>No</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Wallet Config Panel (hidden) -->
            <div class="settings-panel" id="panel-wallet" style="display:none">
                <h2>Wallet Configuration</h2>
                <p class="panel-desc">Prefunded wallet balance alerts and funding settings.</p>

                <div class="form-grid">
                    <div class="form-group">
                        <label>Low Balance Alert Threshold (&#8377;)</label>
                        <input type="number" value="500000">
                        <div class="help-text">Send alert when wallet balance drops below this amount</div>
                    </div>
                    <div class="form-group">
                        <label>Critical Balance Threshold (&#8377;)</label>
                        <input type="number" value="100000">
                        <div class="help-text">Block new payouts when balance drops below this amount</div>
                    </div>
                </div>

                <div class="form-divider"></div>
                <h3 style="margin-bottom:var(--sp-4)">Alert Recipients</h3>
                <div class="form-group">
                    <label>Email Addresses (comma separated)</label>
                    <input type="text" value="abhijeet.anand@abbott.com, finance.team@abbott.com">
                </div>
                <div class="toggle-row">
                    <div>
                        <div class="toggle-label">SMS Alerts</div>
                        <div class="toggle-desc">Send SMS to program manager on low balance</div>
                    </div>
                    <div class="toggle-switch on" onclick="this.classList.toggle('on')"></div>
                </div>
                <div class="toggle-row">
                    <div>
                        <div class="toggle-label">Daily Balance Summary</div>
                        <div class="toggle-desc">Email daily wallet balance report at 9:00 AM</div>
                    </div>
                    <div class="toggle-switch on" onclick="this.classList.toggle('on')"></div>
                </div>
            </div>

            <!-- Notifications Panel (hidden) -->
            <div class="settings-panel" id="panel-notifications" style="display:none">
                <h2>Notification Templates</h2>
                <p class="panel-desc">Customize SMS and email templates sent to retailers and program managers.</p>

                <div class="form-group">
                    <label>KYC Invitation SMS</label>
                    <textarea rows="3">Dear {retailer_name}, Abbott India invites you to complete KYC for the reward program. Click {kyc_link} to verify. Valid for {expiry_hours}hrs.</textarea>
                </div>
                <div class="form-group">
                    <label>OTP Message</label>
                    <textarea rows="3">Your OTP for Abbott reward payout of Rs.{amount} is {otp}. Valid for {expiry_min} minutes. Do not share.</textarea>
                </div>
                <div class="form-group">
                    <label>Payout Confirmation SMS</label>
                    <textarea rows="3">Rs.{net_amount} credited to your bank a/c ending {bank_last4} from Abbott India Rewards. Ref: {imps_ref}. TDS Rs.{tds_amount} deducted.</textarea>
                </div>
                <div class="form-group">
                    <label>Batch Completion Email (Program Manager)</label>
                    <textarea rows="3">Batch {batch_id} completed. {success_count}/{total_count} payouts successful. Net transferred: Rs.{net_amount}. TDS deducted: Rs.{tds_amount}. {failed_count} failures require attention.</textarea>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
function switchSettingsTab(name) {
    document.querySelectorAll('.settings-tab').forEach(function(el) { el.classList.remove('active'); });
    document.querySelectorAll('.settings-panel').forEach(function(el) { el.style.display = 'none'; });
    event.currentTarget.classList.add('active');
    document.getElementById('panel-' + name).style.display = 'block';
}
</script>
{% endblock %}
